generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brand {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  models Model[]
  items  Item[]
}

model Model {
  id      Int    @id @default(autoincrement())
  name    String
  brandId Int
  brand   Brand  @relation(fields: [brandId], references: [id])
  items   Item[]
}

model Item {
  id        Int      @id @default(autoincrement())
  name      String
  amount    Float
  brandId   Int
  modelId   Int?
  createdAt DateTime @default(now())
  brand     Brand    @relation(fields: [brandId], references: [id])
  model     Model?   @relation(fields: [modelId], references: [id])

  @@index([brandId])
  @@index([modelId])
  @@index([createdAt])
}